<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 로고 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="꼬리치레"
            android:textSize="28sp"
            android:textColor="#2D6A4F"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="자동 문자 발송 앱"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 서비스 상태 -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ 문자 발송 서비스 중지됨"
            android:textSize="16sp"
            android:textColor="#999999"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- 배민 감지 상태 -->
        <TextView
            android:id="@+id/baeminStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ 배민 주문 감지 꺼짐"
            android:textSize="16sp"
            android:textColor="#D32F2F"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 알림 접근 권한 버튼 -->
        <Button
            android:id="@+id/notificationSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="알림 접근 권한 켜기"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF6F00"
            android:layout_marginBottom="20dp" />

        <!-- 서버 주소 입력 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="서버 주소"
            android:textSize="14sp"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="https://kkorichire-sms.onrender.com"
            android:inputType="textUri"
            android:textSize="15sp"
            android:padding="14dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="20dp" />

        <!-- 시작/중지 버튼 -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="서비스 시작"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2D6A4F"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="서비스 중지"
            android:textSize="16sp"
            android:textColor="#666666"
            android:backgroundTint="#E0E0E0"
            android:enabled="false"
            android:layout_marginBottom="24dp" />

        <!-- 발송 로그 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="발송 내역"
            android:textSize="14sp"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            android:text="아직 발송 내역이 없습니다"
            android:textSize="12sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            android:background="@drawable/log_background"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
