<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="리뷰집사"
            android:textSize="32sp"
            android:textColor="#2D6A4F"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="60dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="배달 주문 자동 리뷰 요청 서비스"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <!-- 카카오 로그인 -->
        <Button
            android:id="@+id/btnKakao"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="카카오 로그인"
            android:textSize="15sp"
            android:textColor="#3C1E1E"
            android:backgroundTint="#FEE500"
            android:layout_marginBottom="10dp" />

        <!-- 네이버 로그인 -->
        <Button
            android:id="@+id/btnNaver"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="네이버 로그인"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#03C75A"
            android:layout_marginBottom="10dp" />

        <!-- 구글 로그인 -->
        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Google 로그인"
            android:textSize="15sp"
            android:textColor="#333333"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- 구분선 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="또는"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 이메일 간편 로그인 -->
        <EditText
            android:id="@+id/loginEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="이메일로 시작하기"
            android:inputType="textEmailAddress"
            android:textSize="15sp"
            android:padding="14dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="이메일로 시작하기"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2D6A4F"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="가입 즉시 15일 무료 체험!"
            android:textSize="13sp"
            android:textColor="#2D6A4F"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
